# NoAway License API - noaway.app (copia in .env e compila)

PORT=3000
DB_PATH=./licenses.db

# Stripe (checkout + webhook)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL=https://noaway.app/thank-you
STRIPE_CANCEL_URL=https://noaway.app/

# Max devices per license (default 2)
MAX_DEVICES_PER_LICENSE=2

# SMTP - Email con chiave e istruzioni
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@noaway.app

# Link download e nome app (per email)
DOWNLOAD_URL=https://noaway.app/download
APP_NAME=NoAway

# URL API licenze (per app Electron in produzione)
# NOAWAY_LICENSE_API_URL=https://license.noaway.app
